{
  "name": "jogajunto",
  "version": "0.1.0",
  "private": true,
  "description": "JogaJunto MVP — pareador de jogos de tabuleiro (Next.js 15 full-stack + PostgreSQL)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:local": "tsx scripts/dev-db.ts",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.16.0",
    "@tanstack/react-query": "^5.90.0",
    "@vercel/blob": "^1.1.1",
    "fast-xml-parser": "^5.2.5",
    "next": "^15.5.4",
    "next-auth": "5.0.0-beta.29",
    "pino": "^9.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "prisma": "^6.16.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "@embedded-postgres/windows-x64@18.4.0-beta.17": true
  }
}
