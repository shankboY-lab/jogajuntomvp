// JogaJunto MVP — DB-01/DB-02
// Modelo de dados da seção 3 da doc técnica.
// Invariante extra (CHECK user_lo_id < user_hi_id em matches) e a view funnel_daily
// vivem na migration SQL (Prisma não expressa CHECK/VIEW).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IntentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// v3/RF-34 — origem do jogo no catálogo. USER_CREATED = cadastro manual (D2).
enum GameSource {
  BGG
  USER_CREATED
}

// v3/DB-09 — ciclo de vida de grupo (RF-41..49).
enum GroupStatus {
  OPEN
  FULL
  CANCELLED
  EXPIRED
}

enum GroupRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  AUTO_DECLINED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash") // null se só Google (RF-01/02)
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  profile          Profile?
  accounts         Account[]
  games            UserGame[]
  intents          PlayIntent[]
  sentRequests     InterestRequest[] @relation("sent")
  receivedRequests InterestRequest[] @relation("received")
  matchesAsLo      Match[]           @relation("matchLo")
  matchesAsHi      Match[]           @relation("matchHi")
  createdGames     Game[]            @relation("createdGames") // v3 — jogos manuais (RF-34/54)
  createdGroups    Group[]           @relation("createdGroups") // v3 — grupos criados (RF-41)
  groupMemberships GroupMember[]     // v3
  groupRequests    GroupJoinRequest[] @relation("groupRequests") // v3
  notifications    Notification[]    // v3
  events           Event[]

  @@map("users")
}

// OAuth (padrão Auth.js)
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Profile {
  userId            String    @id @map("user_id")
  displayName       String    @map("display_name")
  photoUrl          String?   @map("photo_url")
  city              String
  neighborhood      String?
  lat               Float // NUNCA exposto via API (RNF-07)
  lng               Float // NUNCA exposto via API (RNF-07)
  radiusKm          Int       @default(5) @map("radius_km") // 2|5|10|25 (RF-09)
  whatsapp          String? // E.164; >=1 canal obrigatório
  telegram          String? // username
  locationConsentAt DateTime? @map("location_consent_at") // LGPD (RF-27)
  completedAt       DateTime? @map("completed_at") // dirige RF-04

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lat, lng])
  @@map("profiles")
}

// Catálogo canônico (v3/DB-07). A PK passa a ser `id` interno (cuid); `bggId`
// vira atributo de origem opcional único (RF-34). Jogos BGG e USER_CREATED
// coexistem — `id` é a única FK de jogo no resto do schema (princípio v3 #6).
model Game {
  id            String     @id @default(cuid())
  bggId         Int?       @unique @map("bgg_id") // era a PK; agora origem opcional
  name          String
  yearPublished Int?       @map("year_published")
  thumbnailUrl  String?    @map("thumbnail_url")
  minPlayers    Int?       @map("min_players") // v3 — cadastro manual (RF-32)
  maxPlayers    Int?       @map("max_players")
  source        GameSource @default(BGG)
  createdById   String?    @map("created_by_id") // autor se USER_CREATED; anonimizável (RF-54)
  cachedAt      DateTime   @default(now()) @map("cached_at")

  createdBy User?             @relation("createdGames", fields: [createdById], references: [id], onDelete: SetNull)
  userGames UserGame[]
  intents   PlayIntent[]
  requests  InterestRequest[]
  matches   Match[]
  groups    Group[]

  @@index([name]) // + índice GIN gin_trgm_ops via SQL raw na migration (DB-08)
  @@index([createdById])
  @@map("games")
}

// coleção (RF-14)
model UserGame {
  userId  String   @map("user_id")
  gameId  String   @map("game_id")
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@map("user_games")
}

// "quero jogar" (RF-21)
model PlayIntent {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  gameId    String       @map("game_id")
  status    IntentStatus @default(ACTIVE)
  expiresAt DateTime     @map("expires_at") // premissa: now()+7d
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId, status, expiresAt])
  @@map("play_intents")
}

// pedido "quero jogar com você" (RF-22/23)
model InterestRequest {
  id         String        @id @default(cuid())
  fromUserId String        @map("from_user_id")
  toUserId   String        @map("to_user_id")
  gameId     String        @map("game_id")
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now()) @map("created_at")

  fromUser User @relation("sent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("received", fields: [toUserId], references: [id], onDelete: Cascade)
  game     Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId, gameId]) // idempotência
  @@index([toUserId, status])
  @@map("interest_requests")
}

// aceite mútuo (RF-24) — userLoId < userHiId (CHECK na migration) garante unicidade do par
model Match {
  id        String   @id @default(cuid())
  userLoId  String   @map("user_lo_id")
  userHiId  String   @map("user_hi_id")
  gameId    String   @map("game_id")
  createdAt DateTime @default(now()) @map("created_at")

  userLo       User          @relation("matchLo", fields: [userLoId], references: [id], onDelete: Cascade)
  userHi       User          @relation("matchHi", fields: [userHiId], references: [id], onDelete: Cascade)
  game         Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  groupMembers GroupMember[]

  @@unique([userLoId, userHiId, gameId])
  @@map("matches")
}

// v3/DB-09 — grupo "mesa" 1-para-N (RF-41..50). Vagas com transação (RNF-14).
model Group {
  id        String      @id @default(cuid())
  creatorId String      @map("creator_id")
  gameId    String      @map("game_id")
  name      String // 3–50 chars (RF-41)
  slots     Int // 1..9, CHECK na migration (D5)
  status    GroupStatus @default(OPEN)
  expiresAt DateTime    @map("expires_at") // now()+GROUP_TTL_DAYS (RF-49)
  createdAt DateTime    @default(now()) @map("created_at")

  creator  User               @relation("createdGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  game     Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  requests GroupJoinRequest[]

  @@index([gameId, status])
  @@index([status, expiresAt])
  @@index([creatorId, status]) // limite de 3 abertos (RF-50)
  @@map("groups")
}

model GroupMember {
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  matchId  String   @map("match_id") // match criador↔membro criado no aceite (RF-44)
  joinedAt DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model GroupJoinRequest {
  id         String             @id @default(cuid())
  groupId    String             @map("group_id")
  fromUserId String             @map("from_user_id")
  status     GroupRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now()) @map("created_at")

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser User  @relation("groupRequests", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@unique([groupId, fromUserId]) // idempotência (RF-51)
  @@index([groupId, status])
  @@map("group_join_requests")
}

// v3/DB-09 — notificações de ciclo de vida de grupo (RF-45/47/48/49), inbox.
model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String // group_full | group_cancelled | group_expired | member_left | member_removed
  payload   Json      @default("{}") // {groupId, groupName, gameId, ...}
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// funil (RF-26, RNF-10)
model Event {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @map("user_id") // anonimizado na exclusão de conta
  name      String // enum documentado em src/server/events/names.ts (BE-16)
  props     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@map("events")
}

model BggSearchCache {
  queryNorm String   @id @map("query_norm") // termo normalizado (lower/trim)
  payload   Json
  cachedAt  DateTime @default(now()) @map("cached_at") // TTL 24h

  @@map("bgg_search_cache")
}

// BE-07 — cache Nominatim (forward e reverse), TTL 30 dias
model GeocodeCache {
  key      String   @id // "q:<termo>" ou "r:<lat>,<lng>" (3 casas)
  payload  Json
  cachedAt DateTime @default(now()) @map("cached_at")

  @@map("geocode_cache")
}

// BE-08/INF-06 — token bucket distribuído (Postgres) p/ BGG, Nominatim e rate limit por IP
model RateLimitBucket {
  key       String   @id
  tokens    Float
  updatedAt DateTime @map("updated_at")

  @@map("rate_limit_buckets")
}

// v3/BE-18 — circuit breaker do proxy BGG. Estado compartilhado em Postgres
// (serverless: instâncias concorrentes leem o mesmo breaker). O breaker aberto
// é o ÚNICO gatilho que habilita o cadastro manual (D2), validado server-side.
model CircuitBreaker {
  key       String    @id
  state     String    @default("closed") // closed | open | half_open
  failures  Int       @default(0)
  openedAt  DateTime? @map("opened_at")
  updatedAt DateTime  @default(now()) @map("updated_at")

  @@map("circuit_breakers")
}
