# ===== Banco (INF-02) =====
# PostgreSQL gerenciado (Neon/Supabase/Railway) ou local.
# DIRECT_URL: conexão direta (sem pooler) usada pelo Prisma Migrate.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jogajunto"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/jogajunto"

# ===== Auth.js v5 (BE-01) =====
# Gere com: openssl rand -base64 32  (ou npx auth secret)
AUTH_SECRET="troque-por-um-segredo-aleatorio"
# Google OAuth (console.cloud.google.com -> credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# URL pública do app (produção). Em dev o Auth.js infere http://localhost:3000
# AUTH_URL="https://jogajunto.app"

# ===== Vercel Blob — fotos de perfil (BE-06) =====
BLOB_READ_WRITE_TOKEN=""

# ===== Cron de expiração (DB-04) =====
CRON_SECRET="troque-por-um-segredo-do-cron"

# ===== Integrações =====
# E-mail de contato exigido pela política de uso do Nominatim (BE-07)
NOMINATIM_EMAIL="contato@jogajunto.app"

# ===== Regras de negócio (premissas do PRD, configuráveis) =====
INTENT_TTL_DAYS="7"
REQUEST_TTL_DAYS="7"
# v3 — janela de expiração de grupos (RF-49, premissa 14 dias)
GROUP_TTL_DAYS="14"
# v3/DB-08 — threshold de similaridade trigram p/ dedup de jogos manuais (0..1)
GAME_DEDUP_THRESHOLD="0.35"

# ===== Feature flags v3 (INF-08) — go-live faseado F1->F2->F3 =====
# Espelhadas em NEXT_PUBLIC_* (server + client). "1"/"true" liga; ausente = v2.
# Com todas desligadas o app é byte-a-byte o comportamento v2 (regressão PRD §8).
NEXT_PUBLIC_FEATURE_MANUAL_GAMES=""
NEXT_PUBLIC_FEATURE_EXPLORE=""
NEXT_PUBLIC_FEATURE_GROUPS=""

# ===== Observabilidade (INF-05) =====
SENTRY_DSN=""
